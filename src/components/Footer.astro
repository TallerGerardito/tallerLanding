---
const currentYear = new Date().getFullYear();

const quickLinks = [
  { label: 'Servicios', href: '#servicios' },
  { label: 'Proceso', href: '#proceso' },
  { label: 'Nosotros', href: '#nosotros' },
  { label: 'Equipo', href: '#equipo' },
  { label: 'Galeria', href: '#galeria' },
  { label: 'Contacto', href: '#contacto' },
];
---

<footer class="bg-brand-dark-deep py-12 lg:py-16 text-white">
  <div class="mx-auto max-w-7xl px-4 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 mb-10">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-2.5 mb-4">
          <img src="/logo.jpeg" alt="Taller Gerardito" class="h-8 w-8 rounded-full object-cover ring-1 ring-white/10" />
          <span class="text-lg font-bold">Taller <span class="text-brand-red">Gerardito</span></span>
        </div>
        <p class="text-zinc-500 text-sm leading-relaxed">
          Diagnostico electronico automotriz con certeza y precision. Mas de 10 anos al servicio de San Manuel y la region norte de Honduras.
        </p>
      </div>

      <!-- Quick links -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-[0.2em] text-zinc-500 mb-4">Enlaces</h3>
        <ul class="space-y-2">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} class="text-zinc-400 hover:text-brand-red-light transition-colors text-sm">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact & social -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-[0.2em] text-zinc-500 mb-4">Contacto</h3>
        <ul class="space-y-2 text-zinc-400 text-sm">
          <li>
            <a href="tel:+50489638660" class="hover:text-brand-red-light transition-colors">8963-8660</a>
          </li>
          <li>
            <a href="mailto:gerarnoe21@gmail.com" class="hover:text-brand-red-light transition-colors">gerarnoe21@gmail.com</a>
          </li>
          <li class="text-zinc-500">San Manuel, Cortes, Honduras</li>
        </ul>

        <!-- Social media -->
        <div class="flex gap-3 mt-4">
          <a href="#" aria-label="Facebook" class="flex h-9 w-9 items-center justify-center rounded-lg bg-zinc-800 text-zinc-500 hover:bg-brand-red hover:text-white transition-all">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
            </svg>
          </a>
          <a href="#" aria-label="Instagram" class="flex h-9 w-9 items-center justify-center rounded-lg bg-zinc-800 text-zinc-500 hover:bg-brand-red hover:text-white transition-all">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Copyright -->
    <div class="border-t border-zinc-800 pt-6 text-center">
      <p class="text-zinc-600 text-xs">
        &copy; {currentYear} Taller Gerardito. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>
