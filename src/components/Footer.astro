---
const currentYear = new Date().getFullYear();

const quickLinks = [
  { label: 'Servicios', href: '#servicios' },
  { label: 'Proceso', href: '#proceso' },
  { label: 'Nosotros', href: '#nosotros' },
  { label: 'Equipo', href: '#equipo' },
  { label: 'Galeria', href: '#galeria' },
  { label: 'Contacto', href: '#contacto' },
];
---

<footer class="bg-brand-dark-deep py-12 lg:py-16 text-white">
  <div class="mx-auto max-w-7xl px-4 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 mb-10">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-2.5 mb-4">
          <img src="/logo.jpeg" alt="Taller Gerardito" class="h-8 w-8 rounded-full object-cover ring-1 ring-white/10" />
          <span class="text-lg font-bold">Taller <span class="text-brand-red">Gerardito</span></span>
        </div>
        <p class="text-zinc-500 text-sm leading-relaxed">
          Diagnostico electronico automotriz con certeza y precision. Mas de 10 años al servicio de San Manuel y la region norte de Honduras.
        </p>
      </div>

      <!-- Quick links -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-[0.2em] text-zinc-500 mb-4">Enlaces</h3>
        <ul class="space-y-2">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} class="text-zinc-400 hover:text-brand-red-light transition-colors text-sm">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact & social -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-[0.2em] text-zinc-500 mb-4">Contacto</h3>
        <ul class="space-y-2 text-zinc-400 text-sm">
          <li>
            <a href="tel:+50489638660" class="hover:text-brand-red-light transition-colors">8963-8660</a>
          </li>
          <li>
            <a href="mailto:gerarnoe21@gmail.com" class="hover:text-brand-red-light transition-colors">gerarnoe21@gmail.com</a>
          </li>
          <li class="text-zinc-500">San Manuel, Cortes, Honduras</li>
        </ul>

        <!-- Social media -->
        <div class="flex gap-3 mt-4">
          <a href="https://www.facebook.com/share/18Txscgia6/?mibextid=wwXIfr" target="_blank" rel="noopener" aria-label="Facebook" class="flex h-9 w-9 items-center justify-center rounded-lg bg-zinc-800 text-zinc-500 hover:bg-brand-red hover:text-white transition-all">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Copyright -->
    <div class="border-t border-zinc-800 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-zinc-600 text-xs">
        &copy; {currentYear} Taller Gerardito. Todos los derechos reservados.
      </p>
      <button data-open-policies class="text-zinc-600 hover:text-brand-red-light text-xs transition-colors cursor-pointer">
        Politicas y Garantias
      </button>
    </div>
  </div>
</footer>
