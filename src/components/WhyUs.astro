---
const advantages = [
  {
    title: 'Certeza Diagnostica',
    description: 'Eliminamos el costoso metodo de prueba y error. Identificamos la falla exacta antes de cualquier intervencion.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-7 w-7"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`,
  },
  {
    title: 'Garantia Formal',
    description: 'Politica documentada de garantia en piezas y mano de obra. Respaldamos cada trabajo con compromiso.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-7 w-7"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  },
  {
    title: 'Precio Accesible',
    description: 'Alta calidad a precio competitivo frente a talleres de San Pedro Sula. Tecnologia de punta sin costos elevados.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-7 w-7"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`,
  },
  {
    title: 'Tecnologia Unica',
    description: 'Escaner, osciloscopio, camara endoscopica y banco de pruebas. Herramientas unicas en la zona.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-7 w-7"><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="1" x2="9" y2="4"/><line x1="15" y1="1" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="23"/><line x1="15" y1="20" x2="15" y2="23"/><line x1="20" y1="9" x2="23" y2="9"/><line x1="20" y1="14" x2="23" y2="14"/><line x1="1" y1="9" x2="4" y2="9"/><line x1="1" y1="14" x2="4" y2="14"/></svg>`,
  },
];
---

<section id="por-que" class="py-20 lg:py-28 bg-brand-dark">
  <div class="mx-auto max-w-7xl px-4 lg:px-8">
    <div class="text-center mb-16" data-animate="fade-up">
      <h2 class="text-section-title font-bold text-white mb-4">Por Que Elegirnos</h2>
      <p class="text-section-subtitle text-zinc-400 max-w-2xl mx-auto">
        El unico taller en San Manuel con equipo de diagnostico avanzado completo y garantia formal.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-5" data-animate="stagger">
      {advantages.map((item, index) => (
        <div class="group relative rounded-2xl bg-brand-dark-mid/30 p-6 lg:p-8 border border-zinc-700/50 border-t-2 border-t-brand-red/60 transition-all duration-300 hover:border-brand-red/30 hover:shadow-lg hover:shadow-brand-red/5 hover:scale-[1.02] text-center overflow-hidden">
          <span class="absolute top-3 right-4 text-5xl font-extrabold text-zinc-700/20 font-mono select-none" aria-hidden="true">0{index + 1}</span>
          <div class="relative z-10">
            <div class="mb-5 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-brand-red/10 text-brand-red group-hover:bg-brand-red/20 group-hover:shadow-lg group-hover:shadow-brand-red/10 transition-all duration-300">
              <Fragment set:html={item.icon} />
            </div>
            <h3 class="text-lg font-semibold text-white mb-2">{item.title}</h3>
            <p class="text-zinc-400 leading-relaxed text-sm">{item.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
