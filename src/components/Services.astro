---
const services = [
  {
    title: 'Mecánica General',
    description: 'Mantenimiento preventivo y correctivo, cambio de aceite, frenos, suspensión y dirección para todo tipo de vehículos.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-8 w-8"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
  },
  {
    title: 'Diagnóstico Electrónico',
    description: 'Diagnóstico garantizado con escáner y osciloscopio para motores de gasolina y diésel. Certeza antes de cualquier intervención.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-8 w-8"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/><polyline points="7 10 10 7 13 12 17 8"/></svg>`,
  },
  {
    title: 'Transmisiones',
    description: 'Reparación y mantenimiento de transmisiones automáticas y mecánicas con diagnóstico preciso.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-8 w-8"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>`,
  },
  {
    title: 'Electricidad Automotriz',
    description: 'Diagnóstico y reparación de sistemas eléctricos: alternadores, arrancadores, cableado y sistemas de carga.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-8 w-8"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
  },
  {
    title: 'Electrónica Avanzada',
    description: 'Sistemas de inyección, sensores, módulos de control electrónico y programación de ECU con equipo de última generación.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-8 w-8"><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="1" x2="9" y2="4"/><line x1="15" y1="1" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="23"/><line x1="15" y1="20" x2="15" y2="23"/><line x1="20" y1="9" x2="23" y2="9"/><line x1="20" y1="14" x2="23" y2="14"/><line x1="1" y1="9" x2="4" y2="9"/><line x1="1" y1="14" x2="4" y2="14"/></svg>`,
  },
  {
    title: 'Aire Acondicionado',
    description: 'Diagnóstico, recarga, reparación y mantenimiento del sistema de aire acondicionado automotriz.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-8 w-8"><path d="M12 2v20M2 12h20M6.5 6.5l11 11M17.5 6.5l-11 11"/><path d="M12 2a3 3 0 0 0 0 6 3 3 0 0 0 0-6z" fill="none"/></svg>`,
  },
];
---

<section id="servicios" class="py-20 lg:py-28">
  <div class="mx-auto max-w-7xl px-4 lg:px-8">
    <div class="text-center mb-16" data-animate="fade-up">
      <h2 class="text-section-title font-bold text-neutral-800 mb-4">Nuestros Servicios</h2>
      <p class="text-lg text-neutral-600 max-w-2xl mx-auto">
        Ofrecemos servicios completos de mecánica automotriz y diagnóstico electrónico para todas las marcas de vehículos.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8" data-animate="stagger">
      {services.map((service) => (
        <div class="group rounded-2xl bg-white p-6 lg:p-8 shadow-sm border border-neutral-200 transition-all hover:shadow-md hover:border-brand-red/30">
          <div class="mb-4 flex h-14 w-14 items-center justify-center rounded-xl bg-brand-dark/10 text-brand-dark group-hover:bg-brand-red/10 group-hover:text-brand-red transition-colors">
            <Fragment set:html={service.icon} />
          </div>
          <h3 class="text-xl font-semibold text-neutral-800 mb-2">{service.title}</h3>
          <p class="text-neutral-600 leading-relaxed">{service.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
