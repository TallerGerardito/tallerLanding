---
const brands = [
  { name: 'Toyota', icon: '/icons/toyota.svg' },
  { name: 'Nissan', icon: '/icons/nissan.svg' },
  { name: 'Mazda', icon: '/icons/mazda.svg' },
  { name: 'Honda', icon: '/icons/honda.svg' },
  { name: 'Mitsubishi', icon: '/icons/mitsubishi.svg' },
  { name: 'Hyundai', icon: '/icons/hyundai.svg' },
  { name: 'Jeep', icon: '/icons/jeep.svg' },
  { name: 'Ford', icon: '/icons/ford.svg' },
  { name: 'Chevrolet', icon: '/icons/chevrolet.svg' },
];
---

<section id="marcas" class="py-20 lg:py-28 bg-brand-dark-light">
  <div class="mx-auto max-w-7xl px-4 lg:px-8">
    <div class="text-center mb-16" data-animate="fade-up">
      <h2 class="text-section-title font-bold text-white mb-4">Marcas que Atendemos</h2>
      <p class="text-section-subtitle text-zinc-400 max-w-2xl mx-auto">
        Equipo multimarca para diagnosticar y reparar cualquier modelo.
      </p>
    </div>

    <!-- Marquee container -->
    <div class="overflow-hidden" data-animate="fade-up">
      <div class="flex animate-marquee w-max">
        <!-- First set -->
        {brands.map((brand) => (
          <div class="flex flex-col items-center justify-center gap-3 mx-6 lg:mx-10 shrink-0">
            <div class="flex h-16 w-24 items-center justify-center rounded-xl bg-brand-dark-mid/30 border border-zinc-700/30 p-3 grayscale hover:grayscale-0 transition-all duration-300 hover:border-zinc-600">
              <img src={brand.icon} alt={brand.name} class="h-8 w-auto brightness-0 invert opacity-60 hover:opacity-100 transition-opacity" />
            </div>
            <span class="text-xs font-medium text-zinc-500">{brand.name}</span>
          </div>
        ))}
        <!-- Duplicate set for seamless loop -->
        {brands.map((brand) => (
          <div class="flex flex-col items-center justify-center gap-3 mx-6 lg:mx-10 shrink-0" aria-hidden="true">
            <div class="flex h-16 w-24 items-center justify-center rounded-xl bg-brand-dark-mid/30 border border-zinc-700/30 p-3 grayscale hover:grayscale-0 transition-all duration-300 hover:border-zinc-600">
              <img src={brand.icon} alt="" class="h-8 w-auto brightness-0 invert opacity-60 hover:opacity-100 transition-opacity" />
            </div>
            <span class="text-xs font-medium text-zinc-500">{brand.name}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="text-center mt-8">
      <span class="inline-flex items-center gap-2 rounded-full bg-brand-red/10 border border-brand-red/20 px-4 py-2 text-sm font-semibold text-brand-red">
        y muchas mas
      </span>
    </div>
  </div>
</section>
