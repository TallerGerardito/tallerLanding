---
const brands = [
  'Toyota', 'Nissan', 'Mazda', 'Honda', 'Mitsubishi',
  'Hyundai', 'Jeep', 'Ford', 'Chevrolet',
];
---

<section id="marcas" class="py-20 lg:py-28">
  <div class="mx-auto max-w-7xl px-4 lg:px-8">
    <div class="text-center mb-16" data-animate="fade-up">
      <h2 class="text-section-title font-bold text-neutral-800 mb-4">Marcas que Atendemos</h2>
      <p class="text-lg text-neutral-600 max-w-2xl mx-auto">
        Trabajamos con todas las marcas de vehículos. Nuestro equipo multimarca nos permite diagnosticar y reparar cualquier modelo.
      </p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4 lg:gap-6" data-animate="stagger">
      {brands.map((brand) => (
        <div class="flex items-center justify-center rounded-xl bg-white p-5 lg:p-6 shadow-sm border border-neutral-200 transition-all hover:shadow-md hover:border-brand-blue/30">
          <span class="text-lg font-bold text-neutral-700">{brand}</span>
        </div>
      ))}
      <div class="flex items-center justify-center rounded-xl bg-brand-orange/10 p-5 lg:p-6 border border-brand-orange/20">
        <span class="text-lg font-bold text-brand-orange">y más...</span>
      </div>
    </div>
  </div>
</section>
