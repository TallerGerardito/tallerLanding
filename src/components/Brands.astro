---
const brands = [
  { name: 'Toyota', icon: '/icons/toyota.svg' },
  { name: 'Nissan', icon: '/icons/nissan.svg' },
  { name: 'Mazda', icon: '/icons/mazda.svg' },
  { name: 'Honda', icon: '/icons/honda.svg' },
  { name: 'Mitsubishi', icon: '/icons/mitsubishi.svg' },
  { name: 'Hyundai', icon: '/icons/hyundai.svg' },
  { name: 'Jeep', icon: '/icons/jeep.svg' },
  { name: 'Ford', icon: '/icons/ford.svg' },
  { name: 'Chevrolet', icon: '/icons/chevrolet.svg' },
];
---

<section id="marcas" class="py-20 lg:py-28">
  <div class="mx-auto max-w-7xl px-4 lg:px-8">
    <div class="text-center mb-16" data-animate="fade-up">
      <h2 class="text-section-title font-bold text-neutral-800 mb-4">Marcas que Atendemos</h2>
      <p class="text-lg text-neutral-600 max-w-2xl mx-auto">
        Trabajamos con todas las marcas de vehículos. Nuestro equipo multimarca nos permite diagnosticar y reparar cualquier modelo.
      </p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4 lg:gap-6" data-animate="stagger">
      {brands.map((brand) => (
        <div class="flex flex-col items-center justify-center gap-3 rounded-xl bg-white p-5 lg:p-6 shadow-sm border border-neutral-200 transition-all hover:shadow-md hover:border-brand-dark/30">
          <img src={brand.icon} alt={brand.name} class="h-10 w-auto" />
          <span class="text-sm font-semibold text-neutral-600">{brand.name}</span>
        </div>
      ))}
      <div class="flex items-center justify-center rounded-xl bg-brand-red/10 p-5 lg:p-6 border border-brand-red/20">
        <span class="text-lg font-bold text-brand-red">y más...</span>
      </div>
    </div>
  </div>
</section>
