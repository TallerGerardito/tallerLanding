---
const contactInfo = [
  {
    label: 'Telefono / WhatsApp',
    value: '8963-8660',
    href: 'tel:+50489638660',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`,
  },
  {
    label: 'Correo Electronico',
    value: 'gerarnoe21@gmail.com',
    href: 'mailto:gerarnoe21@gmail.com',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>`,
  },
  {
    label: 'Direccion',
    value: 'San Manuel, Cortes — 2 cuadras arriba del Carwash Mendoza',
    href: '#mapa',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
  },
];

const services = [
  'Cambio de Aceite',
  'Afinamiento de Motor',
  'Diagnostico de Fallas',
  'Cambio de Bateria',
  'Reparacion General',
  'Otro',
];
---

<section id="contacto" class="py-20 lg:py-28 bg-brand-dark-light">
  <div class="mx-auto max-w-7xl px-4 lg:px-8">
    <div class="text-center mb-16" data-animate="fade-up">
      <h2 class="text-section-title font-bold text-white mb-4">Agenda tu Cita</h2>
      <p class="text-section-subtitle text-zinc-400 max-w-2xl mx-auto">
        Completa el formulario y te contactamos por WhatsApp para confirmar tu cita.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 max-w-6xl mx-auto">
      <!-- Form (3 cols) -->
      <div class="lg:col-span-3" data-animate="fade-up">
        <form id="contact-form" class="rounded-2xl bg-brand-dark-mid/30 border border-zinc-700/50 p-6 lg:p-8 space-y-5">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label for="client-name" class="block text-sm font-medium text-zinc-300 mb-1.5">Nombre completo</label>
              <input type="text" id="client-name" name="name" required placeholder="Ej: Juan Perez"
                class="w-full rounded-lg bg-brand-dark/60 border border-zinc-700/50 px-4 py-3 text-sm text-white placeholder:text-zinc-600 focus:outline-none focus:border-brand-red/50 focus:ring-1 focus:ring-brand-red/30 transition-colors" />
            </div>
            <div>
              <label for="client-phone" class="block text-sm font-medium text-zinc-300 mb-1.5">Telefono</label>
              <input type="tel" id="client-phone" name="phone" required placeholder="Ej: 8963-8660"
                class="w-full rounded-lg bg-brand-dark/60 border border-zinc-700/50 px-4 py-3 text-sm text-white placeholder:text-zinc-600 focus:outline-none focus:border-brand-red/50 focus:ring-1 focus:ring-brand-red/30 transition-colors" />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label for="vehicle-info" class="block text-sm font-medium text-zinc-300 mb-1.5">Vehiculo (marca, modelo, año)</label>
              <input type="text" id="vehicle-info" name="vehicle" required placeholder="Ej: Toyota Corolla 2018"
                class="w-full rounded-lg bg-brand-dark/60 border border-zinc-700/50 px-4 py-3 text-sm text-white placeholder:text-zinc-600 focus:outline-none focus:border-brand-red/50 focus:ring-1 focus:ring-brand-red/30 transition-colors" />
            </div>
            <div>
              <label for="service-type" class="block text-sm font-medium text-zinc-300 mb-1.5">Servicio requerido</label>
              <select id="service-type" name="service" required
                class="w-full rounded-lg bg-brand-dark/60 border border-zinc-700/50 px-4 py-3 text-sm text-white focus:outline-none focus:border-brand-red/50 focus:ring-1 focus:ring-brand-red/30 transition-colors appearance-none">
                <option value="" disabled selected class="text-zinc-600">Seleccione un servicio</option>
                {services.map((s) => (
                  <option value={s}>{s}</option>
                ))}
              </select>
            </div>
          </div>

          <div>
            <label for="problem-desc" class="block text-sm font-medium text-zinc-300 mb-1.5">Descripcion del problema</label>
            <textarea id="problem-desc" name="problem" rows="3" placeholder="Describa brevemente la falla o servicio que necesita..."
              class="w-full rounded-lg bg-brand-dark/60 border border-zinc-700/50 px-4 py-3 text-sm text-white placeholder:text-zinc-600 focus:outline-none focus:border-brand-red/50 focus:ring-1 focus:ring-brand-red/30 transition-colors resize-none"></textarea>
          </div>

          <button type="submit"
            class="w-full flex items-center justify-center gap-2 rounded-xl bg-[#25D366] px-6 py-3.5 text-sm font-semibold text-white hover:bg-[#1fba59] transition-all duration-300 hover:scale-[1.02] hover:shadow-lg hover:shadow-[#25D366]/20">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Enviar por WhatsApp
          </button>
        </form>
      </div>

      <!-- Contact info + Hours (2 cols) -->
      <div class="lg:col-span-2 space-y-4" data-animate="stagger">
        {contactInfo.map((item) => (
          <a
            href={item.href}
            class="flex items-start gap-4 rounded-xl bg-brand-dark-mid/30 p-5 border border-zinc-700/50 transition-all duration-300 hover:border-brand-red/30 hover:shadow-lg hover:shadow-brand-red/5 group"
          >
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-brand-red/10 text-brand-red group-hover:bg-brand-red/20 transition-colors">
              <Fragment set:html={item.icon} />
            </div>
            <div>
              <div class="text-xs font-medium text-zinc-500 mb-1">{item.label}</div>
              <div class="text-sm font-semibold text-white group-hover:text-brand-red-light transition-colors">{item.value}</div>
            </div>
          </a>
        ))}

        <!-- Business hours -->
        <div class="rounded-xl bg-brand-dark-mid/30 border border-zinc-700/50 p-5">
          <div class="flex items-start gap-4">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-brand-red/10 text-brand-red">
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10" />
                <polyline points="12 6 12 12 16 14" />
              </svg>
            </div>
            <div>
              <div class="text-xs font-medium text-zinc-500 mb-1">Horario de Atencion</div>
              <div class="text-sm font-semibold text-white">Lunes a Sabado</div>
              <div class="text-brand-red font-bold mt-0.5">8:00 a.m. – 5:00 p.m.</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;

  form?.addEventListener('submit', (e) => {
    e.preventDefault();

    const name = (document.getElementById('client-name') as HTMLInputElement).value.trim();
    const phone = (document.getElementById('client-phone') as HTMLInputElement).value.trim();
    const vehicle = (document.getElementById('vehicle-info') as HTMLInputElement).value.trim();
    const service = (document.getElementById('service-type') as HTMLSelectElement).value;
    const problem = (document.getElementById('problem-desc') as HTMLTextAreaElement).value.trim();

    const message = [
      `Hola, me gustaria agendar una cita en Taller Gerardito.`,
      ``,
      `*Nombre:* ${name}`,
      `*Telefono:* ${phone}`,
      `*Vehiculo:* ${vehicle}`,
      `*Servicio:* ${service}`,
      problem ? `*Descripcion:* ${problem}` : '',
      ``,
      `Quedo atento a su confirmacion. Gracias.`,
    ].filter(Boolean).join('\n');

    const encoded = encodeURIComponent(message);
    window.open(`https://wa.me/50489638660?text=${encoded}`, '_blank');
  });
</script>
