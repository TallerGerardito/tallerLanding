---
const steps = [
  { number: '01', title: 'Contacto', description: 'Nos contactas por WhatsApp o telefono para agendar tu cita.' },
  { number: '02', title: 'Diagnostico', description: 'Evaluamos tu vehiculo con equipo electronico de precision.' },
  { number: '03', title: 'Presupuesto', description: 'Te presentamos un presupuesto detallado y transparente.' },
  { number: '04', title: 'Reparacion', description: 'Ejecutamos el trabajo con piezas de calidad y garantia.' },
  { number: '05', title: 'Entrega', description: 'Recibes tu vehiculo funcionando y con garantia documentada.' },
];
---

<section id="proceso" class="py-20 lg:py-28 bg-brand-dark">
  <div class="mx-auto max-w-7xl px-4 lg:px-8">
    <div class="text-center mb-16" data-animate="fade-up">
      <h2 class="text-section-title font-bold text-white mb-4">Nuestro Proceso</h2>
      <p class="text-section-subtitle text-zinc-400 max-w-2xl mx-auto">
        Un flujo de trabajo claro y transparente desde el primer contacto hasta la entrega.
      </p>
    </div>

    <!-- Desktop: horizontal layout -->
    <div class="hidden lg:block" data-animate="stagger">
      <div class="flex items-start justify-between relative">
        <!-- Connector line -->
        <div class="absolute top-6 left-[10%] right-[10%] h-px bg-zinc-700" aria-hidden="true"></div>

        {steps.map((step) => (
          <div class="relative flex flex-col items-center text-center w-1/5 px-2">
            <div class="relative z-10 flex h-12 w-12 items-center justify-center rounded-full bg-brand-red text-white font-mono font-bold text-sm ring-4 ring-brand-dark mb-4">
              {step.number}
            </div>
            <h3 class="text-base font-semibold text-white mb-1">{step.title}</h3>
            <p class="text-zinc-400 text-sm leading-relaxed">{step.description}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Mobile: vertical layout -->
    <div class="lg:hidden" data-animate="stagger">
      <div class="relative border-l-2 border-zinc-700 ml-6 space-y-10">
        {steps.map((step) => (
          <div class="relative pl-10">
            <div class="absolute -left-[21px] top-0 flex h-10 w-10 items-center justify-center rounded-full bg-brand-red text-white font-mono font-bold text-sm ring-4 ring-brand-dark">
              {step.number}
            </div>
            <h3 class="text-base font-semibold text-white mb-1">{step.title}</h3>
            <p class="text-zinc-400 text-sm leading-relaxed">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
