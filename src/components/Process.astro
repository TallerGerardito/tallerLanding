---
const steps = [
  { number: '01', title: 'Contacto', description: 'Nos contactas por WhatsApp o teléfono para agendar tu cita.', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>` },
  { number: '02', title: 'Diagnóstico', description: 'Evaluamos tu vehículo con equipo electrónico de precisión.', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>` },
  { number: '03', title: 'Presupuesto', description: 'Te presentamos un presupuesto detallado y transparente.', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>` },
  { number: '04', title: 'Reparación', description: 'Ejecutamos el trabajo con piezas de calidad y garantía.', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>` },
  { number: '05', title: 'Entrega', description: 'Recibes tu vehículo funcionando y con garantía documentada.', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>` },
];
---

<section id="proceso" class="py-20 lg:py-28 bg-brand-dark">
  <div class="mx-auto max-w-7xl px-4 lg:px-8">
    <div class="text-center mb-16" data-animate="fade-up">
      <h2 class="text-section-title font-bold text-white mb-4">Nuestro Proceso</h2>
      <p class="text-section-subtitle text-zinc-400 max-w-2xl mx-auto">
        Un flujo de trabajo claro y transparente desde el primer contacto hasta la entrega.
      </p>
    </div>

    <!-- Desktop: horizontal layout -->
    <div class="hidden lg:block" data-animate="stagger">
      <div class="flex items-start justify-between relative">
        <!-- Connector line -->
        <div class="absolute top-6 left-[10%] right-[10%] h-px bg-zinc-700" aria-hidden="true"></div>

        {steps.map((step) => (
          <div class="relative flex flex-col items-center text-center w-1/5 px-2">
            <div class="relative z-10 flex h-12 w-12 items-center justify-center rounded-full bg-brand-red text-white ring-4 ring-brand-dark mb-3">
              <Fragment set:html={step.icon} />
            </div>
            <span class="text-xs font-mono text-brand-red/60 mb-1">{step.number}</span>
            <h3 class="text-base font-semibold text-white mb-1">{step.title}</h3>
            <p class="text-zinc-400 text-sm leading-relaxed">{step.description}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Mobile: vertical layout -->
    <div class="lg:hidden" data-animate="stagger">
      <div class="relative border-l-2 border-zinc-700 ml-6 space-y-10">
        {steps.map((step) => (
          <div class="relative pl-10">
            <div class="absolute -left-[21px] top-0 flex h-10 w-10 items-center justify-center rounded-full bg-brand-red text-white ring-4 ring-brand-dark">
              <Fragment set:html={step.icon} />
            </div>
            <span class="text-xs font-mono text-brand-red/60 mb-0.5">{step.number}</span>
            <h3 class="text-base font-semibold text-white mb-1">{step.title}</h3>
            <p class="text-zinc-400 text-sm leading-relaxed">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
