<section id="inicio" class="relative min-h-[90vh] flex items-center bg-brand-dark overflow-hidden">
  <!-- Background image with dark overlay -->
  <div class="absolute inset-0" aria-hidden="true">
    <img src="/images/gerardo-equipo.jpg" alt="" class="absolute inset-0 w-full h-full object-cover object-center" />
    <div class="absolute inset-0 bg-gradient-to-r from-brand-dark-deep/95 via-brand-dark/90 to-brand-dark/80"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-brand-red/5 rounded-full blur-[120px]"></div>
  </div>

  <!-- Grid pattern overlay -->
  <div class="absolute inset-0 opacity-[0.03]" aria-hidden="true">
    <svg class="h-full w-full" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="grid" width="60" height="60" patternUnits="userSpaceOnUse">
          <path d="M 60 0 L 0 0 0 60" fill="none" stroke="white" stroke-width="0.5" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#grid)" />
    </svg>
  </div>

  <!-- Gradient fade at bottom -->
  <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-brand-dark to-transparent" aria-hidden="true"></div>

  <div class="relative mx-auto max-w-7xl px-4 py-32 pt-40 lg:px-8 w-full">
    <div class="max-w-3xl">
      <!-- Location badge -->
      <div data-animate="hero-badge" class="mb-8 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm text-zinc-400 backdrop-blur-sm">
        <svg class="h-4 w-4 text-brand-red" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
          <circle cx="12" cy="10" r="3" />
        </svg>
        San Manuel, Cortés — Honduras
      </div>

      <!-- Title -->
      <h1 data-animate="hero-title" class="text-hero font-extrabold leading-[1.1] text-white mb-6 tracking-tight">
        Taller <span class="text-brand-red">Gerardito</span>
      </h1>

      <!-- Slogan -->
      <p data-animate="hero-subtitle" class="text-xl lg:text-2xl text-zinc-400 leading-relaxed mb-4 max-w-2xl font-light">
        Diagnóstico electrónico automotriz con <span class="text-zinc-200 font-normal">certeza y precisión</span>
      </p>

      <!-- Experience line -->
      <p data-animate="hero-subtitle" class="text-base text-brand-red font-semibold mb-12 flex items-center gap-2">
        <span class="inline-block w-8 h-px bg-brand-red"></span>
        Más de 10 años de experiencia
      </p>

      <!-- CTA Buttons -->
      <div data-animate="hero-cta" class="flex flex-col sm:flex-row gap-4">
        <a
          href="https://wa.me/50489638660"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center justify-center gap-2 rounded-xl bg-brand-red px-8 py-4 text-lg font-bold text-white transition-all hover:bg-brand-red-light hover:scale-105 hover:shadow-lg hover:shadow-brand-red/25 focus:outline-none focus:ring-2 focus:ring-brand-red focus:ring-offset-2 focus:ring-offset-brand-dark min-h-[48px]"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
          </svg>
          Contáctanos por WhatsApp
        </a>
        <a
          href="#servicios"
          class="inline-flex items-center justify-center gap-2 rounded-xl border border-zinc-700 px-8 py-4 text-lg font-semibold text-zinc-300 transition-all hover:bg-white/5 hover:border-zinc-500 hover:text-white focus:outline-none focus:ring-2 focus:ring-white/20 focus:ring-offset-2 focus:ring-offset-brand-dark min-h-[48px] backdrop-blur-sm"
        >
          Ver Servicios
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M19 14l-7 7m0 0l-7-7m7 7V3" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
