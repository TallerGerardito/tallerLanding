---
const testimonials = [
  {
    name: 'Carlos M.',
    rating: 5,
    text: 'Excelente servicio. Llevé mi Toyota con una falla eléctrica que en otros talleres no pudieron resolver. En Taller Gerardito lo diagnosticaron con el escáner y osciloscopio en menos de una hora. Muy profesionales.',
  },
  {
    name: 'María L.',
    rating: 5,
    text: 'Lo que más me gusta es la honestidad. Don Gerardo me explicó exactamente qué tenía mi vehículo antes de hacer cualquier reparación. Los precios son justos y el trabajo queda garantizado.',
  },
  {
    name: 'Roberto A.',
    rating: 5,
    text: 'Mi Hyundai tenía problemas de transmisión. En San Pedro Sula me querían cobrar el doble. Aquí me lo resolvieron con garantía y a un precio accesible. Totalmente recomendado.',
  },
];

const stars = (count: number) => '★'.repeat(count) + '☆'.repeat(5 - count);
---

<section id="testimonios" class="py-20 lg:py-28 bg-neutral-100">
  <div class="mx-auto max-w-7xl px-4 lg:px-8">
    <div class="text-center mb-16" data-animate="fade-up">
      <h2 class="text-section-title font-bold text-neutral-800 mb-4">Lo Que Dicen Nuestros Clientes</h2>
      <p class="text-lg text-neutral-600 max-w-2xl mx-auto">
        La confianza de nuestros clientes es nuestra mejor carta de presentación.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8" data-animate="stagger">
      {testimonials.map((t) => (
        <div class="rounded-2xl bg-white p-6 lg:p-8 shadow-sm border border-neutral-200">
          <div class="text-brand-orange text-xl mb-3 tracking-wider" aria-label={`${t.rating} de 5 estrellas`}>
            {stars(t.rating)}
          </div>
          <p class="text-neutral-600 leading-relaxed mb-4 italic">"{t.text}"</p>
          <div class="flex items-center gap-3">
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-brand-blue text-white font-bold text-sm">
              {t.name.charAt(0)}
            </div>
            <span class="font-semibold text-neutral-800">{t.name}</span>
          </div>
        </div>
      ))}
    </div>

    <!-- Google Maps review CTA -->
    <div class="text-center mt-12" data-animate="fade-up">
      <p class="text-neutral-600 mb-4">¿Ya nos visitaste? ¡Déjanos tu reseña en Google Maps!</p>
      <a
        href="https://wa.me/50489638660?text=Hola%2C%20me%20gustaría%20agendar%20una%20cita"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 rounded-lg bg-brand-blue px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-brand-blue-light focus:outline-none focus:ring-2 focus:ring-brand-blue focus:ring-offset-2"
      >
        Agenda tu Cita
      </a>
    </div>
  </div>
</section>
