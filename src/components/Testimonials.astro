---
const testimonials = [
  {
    name: 'Carlos M.',
    rating: 5,
    text: 'Excelente servicio. Lleve mi Toyota con una falla electrica que en otros talleres no pudieron resolver. En Taller Gerardito lo diagnosticaron con el escaner y osciloscopio en menos de una hora. Muy profesionales.',
  },
  {
    name: 'Maria L.',
    rating: 5,
    text: 'Lo que mas me gusta es la honestidad. Don Gerardo me explico exactamente que tenia mi vehiculo antes de hacer cualquier reparacion. Los precios son justos y el trabajo queda garantizado.',
  },
  {
    name: 'Roberto A.',
    rating: 5,
    text: 'Mi Hyundai tenia problemas de transmision. En San Pedro Sula me querian cobrar el doble. Aqui me lo resolvieron con garantia y a un precio accesible. Totalmente recomendado.',
  },
];

const stars = (count: number) => '★'.repeat(count) + '☆'.repeat(5 - count);
---

<section id="testimonios" class="py-20 lg:py-28 bg-brand-dark">
  <div class="mx-auto max-w-7xl px-4 lg:px-8">
    <div class="text-center mb-16" data-animate="fade-up">
      <h2 class="text-section-title font-bold text-white mb-4">Lo Que Dicen Nuestros Clientes</h2>
      <p class="text-section-subtitle text-zinc-400 max-w-2xl mx-auto">
        La confianza de nuestros clientes es nuestra mejor carta de presentacion.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 lg:gap-5" data-animate="stagger">
      {testimonials.map((t) => (
        <div class="rounded-2xl bg-brand-dark-mid/30 p-6 lg:p-8 border border-zinc-700/50 relative">
          <!-- Decorative quote -->
          <span class="absolute top-4 right-6 text-6xl font-serif text-brand-red/10 leading-none select-none" aria-hidden="true">"</span>

          <div class="text-brand-red text-lg mb-4 tracking-wider" aria-label={`${t.rating} de 5 estrellas`}>
            {stars(t.rating)}
          </div>
          <p class="text-zinc-300 leading-relaxed mb-6 text-sm relative z-10">"{t.text}"</p>
          <div class="flex items-center gap-3">
            <div class="flex h-11 w-11 items-center justify-center rounded-full bg-gradient-to-br from-brand-red to-brand-red-light text-white font-bold text-sm">
              {t.name.charAt(0)}
            </div>
            <span class="font-semibold text-white text-sm">{t.name}</span>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-12" data-animate="fade-up">
      <p class="text-zinc-500 mb-4 text-sm">Ya nos visitaste? Agenda tu proxima cita</p>
      <a
        href="https://wa.me/50489638660?text=Hola%2C%20me%20gustaria%20agendar%20una%20cita"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 rounded-xl bg-brand-red px-6 py-3 text-sm font-semibold text-white transition-all hover:bg-brand-red-light hover:scale-105 hover:shadow-lg hover:shadow-brand-red/25"
      >
        Agenda tu Cita
      </a>
    </div>
  </div>
</section>
