---
const navLinks = [
  { label: 'Inicio', href: '#inicio' },
  { label: 'Servicios', href: '#servicios' },
  { label: 'Proceso', href: '#proceso' },
  { label: 'Nosotros', href: '#nosotros' },
  { label: 'Equipo', href: '#equipo' },
  { label: 'Galería', href: '#galeria' },
  { label: 'Contacto', href: '#contacto' },
];
---

<header id="navbar" class="fixed top-0 left-0 w-full z-50 transition-all duration-300">
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 lg:px-8">
    <!-- Logo -->
    <a href="#inicio" class="flex items-center gap-2.5 text-white font-bold text-lg tracking-tight">
      <img src="/logo.jpeg" alt="Taller Gerardito" class="h-9 w-9 rounded-full object-cover ring-1 ring-white/10" />
      <span>Taller <span class="text-brand-red">Gerardito</span></span>
    </a>

    <!-- Desktop nav links -->
    <div class="hidden lg:flex items-center gap-1">
      {navLinks.map((link) => (
        <a href={link.href} class="nav-link text-zinc-400 hover:text-white transition-colors text-sm font-medium px-3 py-2 rounded-lg hover:bg-white/5" data-section={link.href.replace('#', '')}>
          {link.label}
        </a>
      ))}
      <a
        href="https://wa.me/50489638660"
        target="_blank"
        rel="noopener"
        class="ml-3 inline-flex items-center gap-2 rounded-lg bg-brand-red px-4 py-2 text-sm font-semibold text-white transition-all hover:bg-brand-red-light hover:scale-105 hover:shadow-lg hover:shadow-brand-red/25"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
        </svg>
        WhatsApp
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button
      id="menu-toggle"
      type="button"
      class="lg:hidden flex flex-col items-center justify-center gap-1.5 p-2 text-white"
      aria-label="Abrir menú de navegación"
      aria-expanded="false"
    >
      <span class="block h-0.5 w-6 bg-current transition-transform duration-300" id="bar1"></span>
      <span class="block h-0.5 w-6 bg-current transition-opacity duration-300" id="bar2"></span>
      <span class="block h-0.5 w-6 bg-current transition-transform duration-300" id="bar3"></span>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-white/5">
    <div class="mx-auto max-w-7xl px-4 py-4 flex flex-col gap-1 bg-brand-dark/95 backdrop-blur-xl">
      {navLinks.map((link) => (
        <a href={link.href} class="mobile-nav-link text-zinc-300 hover:text-white hover:bg-white/5 transition-all text-base font-medium py-3 px-3 rounded-lg">
          {link.label}
        </a>
      ))}
      <a
        href="https://wa.me/50489638660"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center justify-center gap-2 rounded-lg bg-brand-red px-4 py-3 text-base font-semibold text-white transition-colors hover:bg-brand-red-light mt-3"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
        </svg>
        WhatsApp
      </a>
    </div>
  </div>
</header>

<script is:inline>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const navbar = document.getElementById('navbar');
  const bar1 = document.getElementById('bar1');
  const bar2 = document.getElementById('bar2');
  const bar3 = document.getElementById('bar3');

  // Glass effect on scroll
  let lastScroll = 0;
  function updateNavbar() {
    const scrollY = window.scrollY;
    if (scrollY > 50) {
      navbar.classList.add('bg-brand-dark/80', 'backdrop-blur-xl', 'shadow-lg', 'shadow-black/10');
      navbar.classList.add('border-b', 'border-white/5');
    } else {
      navbar.classList.remove('bg-brand-dark/80', 'backdrop-blur-xl', 'shadow-lg', 'shadow-black/10');
      navbar.classList.remove('border-b', 'border-white/5');
    }
    lastScroll = scrollY;
  }
  window.addEventListener('scroll', updateNavbar, { passive: true });
  updateNavbar();

  // Mobile menu toggle
  toggle.addEventListener('click', () => {
    const isOpen = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!isOpen));
    bar1.style.transform = isOpen ? '' : 'rotate(45deg) translate(4px, 4px)';
    bar2.style.opacity = isOpen ? '1' : '0';
    bar3.style.transform = isOpen ? '' : 'rotate(-45deg) translate(4px, -4px)';
  });

  // Active section tracking
  const navLinksEls = document.querySelectorAll('.nav-link');
  const sections = [];
  navLinksEls.forEach((link) => {
    const id = link.getAttribute('data-section');
    const section = document.getElementById(id);
    if (section) sections.push({ id, el: section, link });
  });

  function updateActiveLink() {
    const scrollY = window.scrollY + 120;
    let current = sections[0];
    for (const s of sections) {
      if (s.el.offsetTop <= scrollY) current = s;
    }
    navLinksEls.forEach((l) => {
      l.classList.remove('text-white', 'bg-white/5');
      l.classList.add('text-zinc-400');
    });
    if (current) {
      current.link.classList.add('text-white', 'bg-white/5');
      current.link.classList.remove('text-zinc-400');
    }
  }
  window.addEventListener('scroll', updateActiveLink, { passive: true });
  updateActiveLink();

  document.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
      bar1.style.transform = '';
      bar2.style.opacity = '1';
      bar3.style.transform = '';
    });
  });
</script>
