---
const galleryItems = [
  { label: 'Cadena de Distribucion', image: '/images/gallery/motor-distribucion.jpg', aspect: 'aspect-[3/4]' },
  { label: 'Diagnostico Electronico', image: '/images/gallery/diagnostico-electronico.jpg', aspect: 'aspect-[3/4]' },
  { label: 'Bloque de Motor', image: '/images/gallery/bloque-motor.jpg', aspect: 'aspect-[3/4]' },
  { label: 'Sistema Electrico', image: '/images/gallery/sistema-electrico.jpg', aspect: 'aspect-[16/10]' },
  { label: 'Arbol de Levas', image: '/images/gallery/arbol-levas.jpg', aspect: 'aspect-[3/4]' },
  { label: 'Sistema de Inyeccion', image: '/images/gallery/sistema-inyeccion.jpg', aspect: 'aspect-[16/10]' },
  { label: 'Transmision', image: '/images/gallery/transmision.jpg', aspect: 'aspect-[3/4]' },
  { label: 'Valvulas y Culata', image: '/images/gallery/valvulas-culata.jpg', aspect: 'aspect-[16/10]' },
];
---

<section id="galeria" class="py-20 lg:py-28 bg-brand-dark-light">
  <div class="mx-auto max-w-7xl px-4 lg:px-8">
    <div class="text-center mb-16" data-animate="fade-up">
      <h2 class="text-section-title font-bold text-white mb-4">Nuestro Trabajo</h2>
      <p class="text-section-subtitle text-zinc-400 max-w-2xl mx-auto">
        Resultados que hablan por si solos
      </p>
    </div>

    <!-- Asymmetric collage grid -->
    <div class="grid grid-cols-2 lg:grid-cols-4 auto-rows-[180px] lg:auto-rows-[200px] gap-3 lg:gap-4" data-animate="stagger">
      {galleryItems.map((item, index) => {
        const spanClass = index === 0
          ? 'col-span-2 row-span-2'
          : index === 3 || index === 5
            ? 'col-span-2 lg:col-span-1'
            : '';
        return (
          <button
            type="button"
            class={`gallery-item group relative w-full h-full rounded-xl overflow-hidden cursor-pointer transition-all duration-300 hover:shadow-xl hover:shadow-brand-red/10 ${spanClass}`}
            data-index={index}
            data-label={item.label}
            data-image={item.image}
            aria-label={`Ver: ${item.label}`}
          >
            <img
              src={item.image}
              alt={item.label}
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
              loading="lazy"
            />
            <!-- Hover overlay -->
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/50 transition-all duration-300 flex items-center justify-center">
              <div class="opacity-0 group-hover:opacity-100 transition-all duration-300 scale-90 group-hover:scale-100 flex flex-col items-center gap-2">
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-brand-red/90 text-white">
                  <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
                </div>
                <span class="text-white text-xs font-medium">{item.label}</span>
              </div>
            </div>
            <!-- Label overlay -->
            <div class="absolute bottom-0 left-0 right-0 p-3 bg-gradient-to-t from-black/80 to-transparent group-hover:opacity-0 transition-opacity duration-300">
              <p class="text-xs font-medium text-white">{item.label}</p>
            </div>
          </button>
        );
      })}
    </div>
  </div>
</section>

<!-- Lightbox dialog -->
<dialog id="gallery-lightbox" class="fixed inset-0 m-auto bg-transparent backdrop:bg-brand-dark/90 backdrop:backdrop-blur-xl w-[calc(100%-2rem)] max-w-4xl max-h-[90vh] p-0 rounded-2xl">
  <div class="relative bg-brand-dark-mid border border-zinc-700/50 rounded-2xl overflow-hidden">
    <!-- Close button -->
    <button id="lightbox-close" type="button" class="absolute top-4 right-4 z-10 h-10 w-10 flex items-center justify-center rounded-full bg-black/50 backdrop-blur-sm text-zinc-400 hover:text-white hover:bg-black/70 transition-colors" aria-label="Cerrar">
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
    </button>

    <!-- Image area -->
    <div id="lightbox-content" class="flex items-center justify-center bg-black">
      <img id="lightbox-image" src="" alt="" class="max-h-[70vh] w-full object-contain" />
    </div>

    <!-- Navigation -->
    <div class="flex items-center justify-between p-4 border-t border-zinc-700/50">
      <button id="lightbox-prev" type="button" class="flex items-center gap-2 px-4 py-2 text-sm text-zinc-400 hover:text-white transition-colors rounded-lg hover:bg-white/5" aria-label="Anterior">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Anterior
      </button>
      <div class="text-center">
        <p id="lightbox-label" class="text-sm font-medium text-white"></p>
        <span id="lightbox-counter" class="text-xs text-zinc-500 font-mono"></span>
      </div>
      <button id="lightbox-next" type="button" class="flex items-center gap-2 px-4 py-2 text-sm text-zinc-400 hover:text-white transition-colors rounded-lg hover:bg-white/5" aria-label="Siguiente">
        Siguiente
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </button>
    </div>
  </div>
</dialog>

<script is:inline>
  const dialog = document.getElementById('gallery-lightbox');
  const closeBtn = document.getElementById('lightbox-close');
  const prevBtn = document.getElementById('lightbox-prev');
  const nextBtn = document.getElementById('lightbox-next');
  const labelEl = document.getElementById('lightbox-label');
  const counterEl = document.getElementById('lightbox-counter');
  const imageEl = document.getElementById('lightbox-image');
  const items = document.querySelectorAll('.gallery-item');
  let currentIndex = 0;

  function updateLightbox(index) {
    currentIndex = index;
    const item = items[index];
    const label = item.getAttribute('data-label');
    const image = item.getAttribute('data-image');
    labelEl.textContent = label;
    imageEl.src = image;
    imageEl.alt = label;
    counterEl.textContent = (index + 1) + ' / ' + items.length;
  }

  items.forEach((item) => {
    item.addEventListener('click', () => {
      const index = parseInt(item.getAttribute('data-index'));
      updateLightbox(index);
      dialog.showModal();
    });
  });

  closeBtn.addEventListener('click', () => dialog.close());
  dialog.addEventListener('click', (e) => {
    if (e.target === dialog) dialog.close();
  });

  prevBtn.addEventListener('click', () => {
    updateLightbox((currentIndex - 1 + items.length) % items.length);
  });

  nextBtn.addEventListener('click', () => {
    updateLightbox((currentIndex + 1) % items.length);
  });

  document.addEventListener('keydown', (e) => {
    if (!dialog.open) return;
    if (e.key === 'ArrowLeft') prevBtn.click();
    if (e.key === 'ArrowRight') nextBtn.click();
  });
</script>
